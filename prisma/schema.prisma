generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  role        String   @default("USER")
  displayName String?
  password    String? // For simple local auth if needed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  image       String
  category    String
  brand       String
  stock       Int      @default(0)
  rating      Float    @default(0)
  reviews     Int      @default(0)
  isNew       Boolean  @default(false)
  isSale      Boolean  @default(false)
  discount    Int?
  specs       String?
  variants    ProductVariant[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String
  stock     Int     @default(0)
  images    String  // JSON array of strings
  price     Float?  // Optional override price
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerEmail   String
  customerPhone   String
  address         String
  city            String
  totalAmount     Float
  status          String      @default("PENDING")
  paymentMethod   String
  paymentStatus   String      @default("UNPAID")
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  name      String
  quantity  Int
  price     Float
  image     String
}

model Review {
  id        String   @id @default(cuid())
  productId String
  user      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model Invite {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  role      String   @default("ADMIN")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model Discount {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String   // "Percentage", "Fixed Amount", "Free Shipping"
  value     String   // "15%", "$100", "$0"
  maxUses   Int?     // Null means unlimited uses
  usedCount Int      @default(0)
  status    String   @default("Active") // "Active", "Paused", "Expired"
  campaign  String   @default("General Promotion")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
